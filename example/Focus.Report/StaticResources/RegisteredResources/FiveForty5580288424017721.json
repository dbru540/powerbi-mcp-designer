{
  "name": "FiveForty",
  "textClasses": {
    "label": {
      "fontSize": 8
    },
    "title": {
      "fontSize": 10
    }
  },
  "dataColors": [
    "#722281",
    "#25B4B0",
    "#A72FBD",
    "#1D8683",
    "#B86FC5",
    "#71B2B0",
    "#DB3FF9",
    "#004A47"
  ],
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#722281"
              }
            },
            "show": false
          }
        ],
        "visualHeader": [
          {
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "foreground": {
              "solid": {
                "color": "#722281"
              }
            }
          }
        ],
        "visualTooltip": [
          {
            "titleFontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "valueFontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "background": {
              "solid": {
                "color": "#722281"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "foregroundColor": {
              "solid": {
                "color": "#722281"
              }
            },
            "titleSize": 12,
            "headerSize": 10
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "foregroundColor": {
              "solid": {
                "color": "#722281"
              }
            }
          },
          {
            "$id": "Available",
            "foregroundColor": {
              "solid": {
                "color": "#722281"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 100
          }
        ]
      }
    }
  }
}