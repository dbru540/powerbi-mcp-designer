expression 'Azure Active directory' = ```
		let
		    // ===================================================================================
		    // Authentication Parameters
		    // ===================================================================================
		    clientId     = "d73fe3b7-b675-48b5-bbd6-82ff2a94e581",
		    clientSecret = "<REPLACE_WITH_AZURE_AD_CLIENT_SECRET>",
		    tenantId     = "ee7b4ccb-8e30-435c-9368-1fce958df645",
		    tokenEndpoint= "https://login.microsoftonline.com/" & tenantId & "/oauth2/v2.0/token",
		    resource     = "https://graph.microsoft.com",
		
		    tokenRequestBody = [
		        client_id     = clientId,
		        client_secret = clientSecret,
		        grant_type    = "client_credentials",
		        scope         = resource & "/.default"
		    ],
		    tokenResponse = Json.Document(
		        Web.Contents(tokenEndpoint, [
		            Headers = [ #"Content-Type" = "application/x-www-form-urlencoded" ],
		            Content = Text.ToBinary(Uri.BuildQueryString(tokenRequestBody))
		        ])
		    ),
		    accessToken = tokenResponse[access_token],
		    authHeader  = [ Authorization = "Bearer " & accessToken ],
		
		    // ----------------------------------------
		    // 2) Recursive Pagination Function
		    // ----------------------------------------
		    //   Always call the same base URL, passing $select + optional $skiptoken
		    GetUsersPage = (skipToken as nullable text) as table =>
		        let
		            baseUrl      = "https://graph.microsoft.com/v1.0/users",
		            pageQuery    = if skipToken = null
		                           then [ #"$select" = "id,mail" ]
		                           else [ #"$select" = "id,mail", #"$skiptoken" = skipToken ],
		            response     = Json.Document(
		                             Web.Contents(baseUrl,
		                               [
		                                 Headers = authHeader,
		                                 Query   = pageQuery
		                               ]
		                             )
		                           ),
		            currentRows  = Table.FromRecords(response[value]),
		
		            // extract skiptoken from nextLink
		            nextLink     = try response[#"@odata.nextLink"] otherwise null,
		            nextToken    = if nextLink <> null
		                           then Text.AfterDelimiter(nextLink, "$skiptoken=")
		                           else null,
		
		            // recurse if needed
		            tailTable    = if nextToken <> null 
		                           then @GetUsersPage(nextToken)
		                           else #table(type table [id=text, mail=text], {}),
		
		            allRows      = Table.Combine({ currentRows, tailTable })
		        in
		            allRows,
		
		    // ----------------------------------------
		    // 3) Fetch All Users & Expand Managers
		    // ----------------------------------------
		    allUsers        = GetUsersPage(null),
		
		    withManagers    = Table.AddColumn(
		                         allUsers,
		                         "ManagerRecord",
		                         each try Json.Document(
		                                 Web.Contents(
		                                   "https://graph.microsoft.com/v1.0/users/",
		                                   [
		                                     Headers = authHeader,
		                                     Query   = [ #"$select" = "mail" ],
		                                     RelativePath = _[id] & "/manager"
		                                   ]
		                                 )
		                               ) otherwise null
		                       ),
		
		    expandedManagers = Table.ExpandRecordColumn(
		                         withManagers,
		                         "ManagerRecord",
		                         {"mail"},
		                         {"Manager Email"}
		                       ),
		    #"Columns removed by Measure Killer"= Table.RemoveColumns(expandedManagers,{"id"})
		in
		    #"Columns removed by Measure Killer"
		```
	lineageTag: 51652a59-05f0-47f2-a1ca-3160f1dd7af2
	queryGroup: DataImport

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Exception

