table Budget
	lineageTag: 329d9969-37de-45f6-a072-3699c935383a

	measure Budget = CALCULATE(SUM(Budget[Amount]),CONTAINSSTRING(Budget[Budget type],"Budget"))
		displayFolder: 1 - Measures
		lineageTag: f5ba8ca8-4530-4018-9ffc-bc9e717bdb56

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Budget (CY)' =
			
			
			CALCULATE(
			    [Budget],
			    FILTER('Calendar',CONVERT(YEAR(TODAY()),STRING)='Calendar'[Year]),
			    USERELATIONSHIP('Calendar'[Date],Budget[Date])
			)
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: 1 - Measures
		lineageTag: b8106715-4fda-4c06-90da-d6638abb47f1

	measure Actual = CALCULATE(-SUM(Budget[Amount]),CONTAINSSTRING(Budget[Budget type],"Actual"))
		displayFolder: 1 - Measures
		lineageTag: 78f10b24-eab9-45cc-a32e-1f2634aee2df

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Actual (CY)' =
			
			
			CALCULATE(
			    [Actual],
			    FILTER('Calendar',CONVERT(YEAR(TODAY()),STRING)='Calendar'[Year]),
			    USERELATIONSHIP('Calendar'[Date],Budget[Date])
			)
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: 1 - Measures
		lineageTag: 779c69bd-9c52-4a67-93e1-404ee76ad4bd

	measure 'Remaining budget (CY)' = [Budget (CY)] - [Actual (CY)]
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		displayFolder: 1 - Measures
		lineageTag: 840d22f2-6078-47a0-a88f-1361595ef26b

	measure 'Remaining budget per remaining CY months' = ```
			
			VAR RemainCY  = [Remaining budget (CY)]
			VAR CurrYear  = YEAR( TODAY() )
			
			// 1) Generate numbers 1→12 for each month
			VAR MonthNums =
			    GENERATESERIES( 1, 12, 1 )
			
			// 2) For each month, fetch your [Actual], force blank→0
			VAR MonthActuals =
			    ADDCOLUMNS(
			        MonthNums,
			        "ActValue",
			        COALESCE(
			            CALCULATE(
			                [Actual],
			                // ignore any existing Budget filters on Date
			                FILTER(
			                    ALL( Budget ),
			                    YEAR( Budget[Date] ) = CurrYear
			                    && MONTH( Budget[Date] ) = [Value]
			                )
			            ),
			            0
			        )
			    )
			
			// 3) Count only those months whose actual = 0
			VAR MonthsRem =
			    COUNTROWS(
			        FILTER( MonthActuals, [ActValue] = 0 )
			    )
			
			// 4) Divide, safely handling divide-by-zero
			RETURN
			DIVIDE( RemainCY, MonthsRem, BLANK() )
			
			```
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		displayFolder: 1 - Measures
		lineageTag: 251ed723-2a91-4188-b0ca-a8dea4c05bc9

