	column FixedProjectRoot = ```
			
			IF(
			    'Power BI - All projects'[Area lvl 2] <> "Project_Priced",
			    BLANK(),
			    VAR thisPath =
			        PATH(
			            'Power BI - All projects'[Work Item Id],
			            'Power BI - All projects'[Parent Work Item Id]
			        )
			    VAR pathLen = PATHLENGTH( thisPath )
			    VAR picks =
			        ADDCOLUMNS(
			            GENERATESERIES( 1, pathLen, 1 ),
			            "AncestorId", PATHITEM( thisPath, [Value], INTEGER ),
			            "FixedId",
			                LOOKUPVALUE(
			                    'Power BI - All projects'[Fixed priced tickets.Work Item Id],
			                    'Power BI - All projects'[Work Item Id],
			                    PATHITEM( thisPath, [Value], INTEGER )
			                )
			        )
			    RETURN
			        MAXX( picks, [FixedId] )
			)
			
			```
		formatString: 0
		lineageTag: 3c4ddb0d-a5a1-44a0-9ac9-56896b4f38fd
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

