	column 'Time & Materials Project Root' =
			
			IF(
			    'Power BI - All projects'[Area lvl 2] = "Project_Priced",
			    BLANK(),
			    VAR thisPath =
			        PATH(
			            'Power BI - All projects'[Work Item Id],
			            'Power BI - All projects'[Parent Work Item Id]
			        )
			    VAR pathLen = PATHLENGTH( thisPath )
			    VAR picks =
			        ADDCOLUMNS(
			            GENERATESERIES( 1, pathLen, 1 ),
			            "AncestorId", PATHITEM( thisPath, [Value], INTEGER ),
			            "FixedId",
			                LOOKUPVALUE(
			                    'Power BI - All projects'[Fixed priced tickets.Work Item Id],
			                    'Power BI - All projects'[Work Item Id],
			                    PATHITEM( thisPath, [Value], INTEGER )
			                )
			        )
			    RETURN
			        MAXX( picks, [FixedId] )
			)
		formatString: 0
		lineageTag: dbe775f5-2e83-4168-9594-37580885a1ff
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition 'Power BI - All projects' = m
		mode: import
		queryGroup: DataModel
		source =
				let
				    // 1) Pull your Analytics view
				    Source = VSTS.AnalyticsViews("fiveforty", "interne", []){[Id="51f6547a-614b-4054-8346-7ec03e65967e", Kind="Table"]}[Data],
				    // 2) Replace pipe in Title and cast all dates at once
				    Cleaned = Table.TransformColumnTypes(
				        Table.ReplaceValue(Source, "|", "/", Replacer.ReplaceText, {"Title"}),
				        {
				            {"Changed Date", type datetime},
				            {"Created Date", type date},
				            {"Closed Date",   type date},
				            {"Resolved Date", type date}
				        }
				    ),
				
				    // 4) Add merged “Work Item” column & split your Area Path
				    WithWorkItem = Table.AddColumn(
				        Cleaned,
				        "Work Item",
				        each Number.ToText([Work Item Id]) & " - " & [Title],
				        type text
				    ),
				    SplitAreaPath = Table.SplitColumn(
				        WithWorkItem,
				        "Area Path",
				        Splitter.SplitTextByDelimiter("\", QuoteStyle.Csv),
				        {"Team Project","Area lvl 2","Area lvl 3"}
				    ),
				
				    // 5) Build your DevOps link
				    WithLink = Table.AddColumn(
				        SplitAreaPath,
				        "Link",
				        each
				            "https://dev.azure.com/fiveforty/" &
				            [Team Project] &
				            "/_workitems/edit/" &
				            Number.ToText([Work Item Id]),
				        type text
				    ),
				
				    // 6) Left‐join to your fixed-price tickets and expand its ID
				    JoinedFixed = Table.NestedJoin(
				        WithLink,
				        "Work Item Id",
				        #"Budgeted tickets",
				        "Work Item Id",
				        "FixedTickets",
				        JoinKind.LeftOuter
				    ),
				    ExpandedFixed = Table.ExpandTableColumn(
				        JoinedFixed,
				        "FixedTickets",
				        {"Work Item Id"},
				        {"Fixed priced tickets.Work Item Id"}
				    ),
				
				    // 7) Self-join on Parent→Work Item to pull in the parent’s Title
				    ParentJoined = Table.NestedJoin(
				        ExpandedFixed,
				        {"Parent Work Item Id"},
				        ExpandedFixed,
				        {"Work Item Id"},
				        "ParentRows",
				        JoinKind.LeftOuter
				    ),
				    Result = Table.ExpandTableColumn(
				        ParentJoined,
				        "ParentRows",
				        {"Title"},
				        {"Parent Title"}
				    ),
				    #"Removed Duplicates" = Table.Distinct(Result),
				    #"Columns removed by Measure Killer"= Table.RemoveColumns(#"Removed Duplicates",{"Work Item Type","Assigned To","Priority","Created Date"})
				in
				    #"Columns removed by Measure Killer"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

