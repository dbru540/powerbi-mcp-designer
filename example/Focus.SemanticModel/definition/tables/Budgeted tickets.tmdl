	measure 'Time & Materials - Remaining % of ongoing projects' = CALCULATE([Time & Materials - Remaining %],'Budgeted tickets'[Amount]<>0 && 'Budgeted tickets'[State] <> "Closed")
		formatString: 0%;-0%;0%
		displayFolder: 1 - Measures
		lineageTag: 08b78ffe-f6a7-4d3a-8175-5cd5d3bee6fd

	measure 'Fixed price - Stage of ongoing projects' = ```
			
			/* ---------------------------------------------------------------------------
			Purpose
			- Return a stage label for ongoing fixed-price projects.
			- If the related user story is Resolved/Closed, show:
			      "Story closed since <Closed Date or Resolved Date>"
			  (prefer Closed Date; if blank, use Resolved Date).
			
			Data sources
			- Dates and states come from 'Power BI - All projects'.
			
			Notes
			- Relationship context is enforced via USERELATIONSHIP to bind Projects and
			  Budgeted tickets to the appropriate work item roots.
			--------------------------------------------------------------------------- */
			
			VAR Budget =
			    [Fixed price - Budget amount of ongoing projects]
			
			/* ---------------------------
			  Closure detection (any root)
			---------------------------- */
			VAR IsUserStoryClosed =
			    (
			        CALCULATE (
			            COUNTROWS ( 'Power BI - All projects' ),
			            'Power BI - All projects'[Work Item Id] = 'Power BI - All projects'[FixedProjectRoot],
			            'Power BI - All projects'[State] IN { "Resolved", "Closed" },
			            USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			            USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[FixedProjectRoot] )
			        )
			        +
			        CALCULATE (
			            COUNTROWS ( 'Power BI - All projects' ),
			            'Power BI - All projects'[Work Item Id] = 'Power BI - All projects'[Time & Materials Project Root],
			            'Power BI - All projects'[State] IN { "Resolved", "Closed" },
			            USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			            USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[Time & Materials Project Root] )
			        )
			    ) > 0
			
			/* ---------------------------------------------------------
			  Closure date (prefer Closed Date, else Resolved Date)
			---------------------------------------------------------- */
			VAR ClosedOrResolvedDate_Fixed =
			    CALCULATE (
			        MAXX (
			            'Power BI - All projects',
			            COALESCE (
			                'Power BI - All projects'[Closed Date],
			                'Power BI - All projects'[Resolved Date]
			            )
			        ),
			        'Power BI - All projects'[Work Item Id] = 'Power BI - All projects'[FixedProjectRoot],
			        'Power BI - All projects'[State] IN { "Resolved", "Closed" },
			        USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			        USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[FixedProjectRoot] )
			    )
			
			VAR ClosedOrResolvedDate_TM =
			    CALCULATE (
			        MAXX (
			            'Power BI - All projects',
			            COALESCE (
			                'Power BI - All projects'[Closed Date],
			                'Power BI - All projects'[Resolved Date]
			            )
			        ),
			        'Power BI - All projects'[Work Item Id] = 'Power BI - All projects'[Time & Materials Project Root],
			        'Power BI - All projects'[State] IN { "Resolved", "Closed" },
			        USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			        USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[Time & Materials Project Root] )
			    )
			
			VAR ClosedOrResolvedDate =
			    COALESCE ( ClosedOrResolvedDate_Fixed, ClosedOrResolvedDate_TM )
			
			/* ---------------------------------
			  Activity-based stage fallbacks
			---------------------------------- */
			VAR IsRequirementActivityMatch =
			    CALCULATE (
			        COUNTROWS ( 'Power BI - All projects' ),
			        'Power BI - All projects'[Activity] = "Requirements"
			            && 'Power BI - All projects'[State] IN { "New", "Active", "Resolved" },
			        USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			        USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[Time & Materials Project Root] )
			    ) > 0
			
			VAR IsDesignActivityMatch =
			    CALCULATE (
			        COUNTROWS ( 'Power BI - All projects' ),
			        'Power BI - All projects'[Activity] = "Design"
			            && 'Power BI - All projects'[State] IN { "New", "Active", "Resolved" },
			        USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			        USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[FixedProjectRoot] )
			    ) > 0
			
			VAR IsEstimateActivityMatch =
			    CALCULATE (
			        COUNTROWS ( 'Power BI - All projects' ),
			        'Power BI - All projects'[Activity] = "Estimate"
			            && 'Power BI - All projects'[State] IN { "New", "Active", "Resolved" },
			        USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			        USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[FixedProjectRoot] )
			    ) > 0
			
			VAR IsDevelopmentActivityActive =
			    CALCULATE (
			        COUNTROWS ( 'Power BI - All projects' ),
			        'Power BI - All projects'[Activity] = "Development"
			            && 'Power BI - All projects'[State] IN { "New", "Active", "Resolved" },
			        USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			        USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[FixedProjectRoot] )
			    ) > 0
			
			VAR IsTestingActivityActive =
			    CALCULATE (
			        COUNTROWS ( 'Power BI - All projects' ),
			        'Power BI - All projects'[Activity] = "Testing"
			            && 'Power BI - All projects'[State] IN { "New", "Active", "Resolved" },
			        USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			        USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[Time & Materials Project Root] )
			    ) > 0
			
			VAR IsDeploymentActivityActive =
			    CALCULATE (
			        COUNTROWS ( 'Power BI - All projects' ),
			        'Power BI - All projects'[Activity] = "Deployment"
			            && 'Power BI - All projects'[State] IN { "New", "Active", "Resolved" },
			        USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			        USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[Time & Materials Project Root] )
			    ) > 0
			
			/* -------------------
			  Label calculations
			-------------------- */
			VAR ClosedLabel =
			    IF (
			        NOT ISBLANK ( ClosedOrResolvedDate ),
			        "Story closed since " & FORMAT ( ClosedOrResolvedDate, "[$-en-US]mmm d" ),
			        "Story closed"
			    )
			
			RETURN
			    IF (
			        NOT ISBLANK ( Budget ),
			        IF (
			            IsUserStoryClosed,
			            ClosedLabel,
			            IF (
			                IsRequirementActivityMatch, "Requirement",
			                IF (
			                    IsDesignActivityMatch, "Specification",
			                    IF (
			                        IsEstimateActivityMatch, "Estimate",
			                        IF (
			                            IsDevelopmentActivityActive, "Development",
			                            IF ( IsTestingActivityActive, "Testing",
			                                IF ( IsDeploymentActivityActive, "Deployment", BLANK () )
			                            )
			                        )
			                    )
			                )
			            )
			        )
			    )
			
			```
		displayFolder: 1 - Measures
		lineageTag: d705e4c8-1445-4a11-b689-424590a1965e

	measure 'Fixed price - Specification Actual amount of ongoing projects' = CALCULATE([Fixed price - Actual amount],'Budgeted tickets'[Amount]<>0, 'Power BI - All projects'[Activity] = "Design" )
		displayFolder: 1 - Measures
		lineageTag: c0c3b762-533a-4afa-a2ff-36727153c5ec

