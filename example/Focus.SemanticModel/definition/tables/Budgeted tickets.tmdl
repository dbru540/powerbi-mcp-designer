	measure 'Time & Materials - Time Final' = ```
			
			
			var _timetype = SELECTEDVALUE(TimeType[Time])
			var _timeandmaterialsBillableHours = 
			
			CALCULATE([BillableHours],
			                FILTER(
			                    'Budgeted tickets',
			                    (CONTAINSSTRING('Budgeted tickets'[Type], "Time & materials") || CONTAINSSTRING('Budgeted tickets'[Type], "Time") || CONTAINSSTRING('Budgeted tickets'[Type], "T&M")) && 'Budgeted tickets'[State] <> "Closed"
			                ),
			                USERELATIONSHIP(Projects[Project Name],'Budgeted tickets'[Team Project]),
			                USERELATIONSHIP('Budgeted tickets'[Work Item Id],'Power BI - All projects'[Time & Materials Project Root] )
			                
			                 )
			var _timeandmaterialsBillableAmount = 
			
			CALCULATE([Billable Amount],
			                FILTER(
			                    'Budgeted tickets',
			                    (CONTAINSSTRING('Budgeted tickets'[Type], "Time & materials") || CONTAINSSTRING('Budgeted tickets'[Type], "Time") || CONTAINSSTRING('Budgeted tickets'[Type], "T&M")) && 'Budgeted tickets'[State] <> "Closed"
			                ),
			                USERELATIONSHIP(Projects[Project Name],'Budgeted tickets'[Team Project]),
			                USERELATIONSHIP('Budgeted tickets'[Work Item Id],'Power BI - All projects'[Time & Materials Project Root] )
			                 
			                 )
			RETURN
			
			IF(_timetype = "Per hour",
			    _timeandmaterialsBillableHours,
			    IF( _timetype = "Per day",_timeandmaterialsBillableHours/8, 
			
			_timeandmaterialsBillableAmount))
			```
		formatString: 0
		displayFolder: 1 - Measures
		lineageTag: 8e893d98-beb0-4669-a07c-e95f885419f3

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Time & Materials - Time Final Cumulated' =
			
			
			VAR CurrentDate =
			    MAXX ( VALUES ( 'Calendar'[Date] ), 'Calendar'[Date] )
			VAR TodayDate = TODAY()
			RETURN
			IF (
			    CurrentDate > EOMONTH ( TodayDate, 0 ),        -- future months are blank
			    BLANK(),
			    CALCULATE (
			        [Time & Materials - Time Final],
			        FILTER (
			            ALLSELECTED ( 'Calendar'[Date] ),
			            'Calendar'[Date] <= CurrentDate
			                && 'Calendar'[Date] <= TodayDate
			        )
			    )
			)
		displayFolder: 1 - Measures
		lineageTag: 4dc93c55-26b8-44ba-9352-b13da960c1e1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

