	measure 'Fixed price - Stage Color of ongoing projects' = ```
			
			
			/* ---------------------------------------------------------------------------
			Purpose
			- Return a hex color for status formatting:
			    - Red  (#FF9999): Closed/Resolved exists AND
			        (today is within 5 days of month-end OR the closure month is last month)
			    - Orange (#FFCC99): Closed/Resolved exists AND older than 5 days vs. today
			    - Otherwise: BLANK()
			
			Data source
			- Closed/Resolved dates come from 'Power BI - All projects'.
			
			Usage
			- Use this measure for visual conditional formatting: Format by → Field value.
			--------------------------------------------------------------------------- */
			
			VAR TodayDate = TODAY()
			VAR EndOfThisMonth = EOMONTH(TodayDate, 0)
			VAR DaysToEOM = INT( EndOfThisMonth - TodayDate )
			
			/* ---------------------------------------------------------
			  Compute the closure date: prefer Closed Date, else Resolved
			  We evaluate for both roots and take the first non-blank.
			---------------------------------------------------------- */
			VAR ClosedOrResolvedDate_Fixed =
			    CALCULATE (
			        MAXX (
			            'Power BI - All projects',
			            COALESCE (
			                'Power BI - All projects'[Closed Date],
			                'Power BI - All projects'[Resolved Date]
			            )
			        ),
			        'Power BI - All projects'[Work Item Id] = 'Power BI - All projects'[FixedProjectRoot],
			        'Power BI - All projects'[State] IN { "Resolved", "Closed" },
			        USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			        USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[FixedProjectRoot] )
			    )
			
			VAR ClosedOrResolvedDate_TM =
			    CALCULATE (
			        MAXX (
			            'Power BI - All projects',
			            COALESCE (
			                'Power BI - All projects'[Closed Date],
			                'Power BI - All projects'[Resolved Date]
			            )
			        ),
			        'Power BI - All projects'[Work Item Id] = 'Power BI - All projects'[Time & Materials Project Root],
			        'Power BI - All projects'[State] IN { "Resolved", "Closed" },
			        USERELATIONSHIP ( Projects[Project Name], 'Budgeted tickets'[Team Project] ),
			        USERELATIONSHIP ( 'Budgeted tickets'[Work Item Id], 'Power BI - All projects'[Time & Materials Project Root] )
			    )
			
			VAR ClosedOrResolvedDate =
			    COALESCE ( ClosedOrResolvedDate_Fixed, ClosedOrResolvedDate_TM )
			
			VAR HasClosure = NOT ISBLANK ( ClosedOrResolvedDate )
			
			/* ---------------------------------------------------------
			  Red conditions:
			  1) Today within 5 days of EOM (0..5 inclusive), AND a closure date exists.
			  2) Closure month is the PREVIOUS month relative to today.
			---------------------------------------------------------- */
			VAR IsWithin5DaysOfEOM = DaysToEOM >= 0 && DaysToEOM <= 5
			VAR IsPreviousMonth =
			    EOMONTH ( ClosedOrResolvedDate, 0 ) = EOMONTH ( TodayDate, -1 )
			
			/* ---------------------------------------------------------
			  Orange condition:
			  - Closure date is >5 days in the past relative to today.
			---------------------------------------------------------- */
			VAR DaysPast = DATEDIFF ( ClosedOrResolvedDate, TodayDate, DAY )
			VAR IsPastMoreThan5Days = DaysPast > 5
			
			RETURN
			    IF (
			        HasClosure &&
			        ( IsWithin5DaysOfEOM || IsPreviousMonth ),
			        "#FF9999",                                     -- Red
			        IF ( HasClosure && IsPastMoreThan5Days, "#FFCC99", BLANK() )   -- Orange else BLANK
			    )
			
			```
		displayFolder: 1 - Measures
		lineageTag: 413f601c-e98a-4d00-88c5-3a31018f0daa

	measure 'Fixed price - Actual percentage of ongoing projects' = ```
			
			/* ---------------------------------------------------------------------------
			Purpose
			- Return the actual "Specification" (Design activity) amount for ongoing
			  fixed-price projects, ensuring that:
			    • The Budgeted ticket Amount is not blank or zero
			    • The State is not "Closed"
			    • The Activity = "Design"
			
			Data sources
			- 'Budgeted tickets' table for Amount and State
			- 'Power BI - All projects' for Activity
			--------------------------------------------------------------------------- */
			
			VAR SpecificationActualAmount =
			    CALCULATE(
			        [Fixed price - Actual amount],
			        
			        FILTER(
			            'Budgeted tickets',
			            NOT ISBLANK('Budgeted tickets'[Amount]) &&
			            'Budgeted tickets'[Amount] <> 0 &&
			            'Budgeted tickets'[State] <> "Closed"
			        ),
			        
			        'Power BI - All projects'[Activity] = "Design"
			    )
			
			RETURN
			    DIVIDE(
			        SpecificationActualAmount,
			        [Fixed price - Budget amount of ongoing projects]
			    )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1 - Measures
		lineageTag: aa24d2db-1383-44ae-b7b6-3a143b4a0999

