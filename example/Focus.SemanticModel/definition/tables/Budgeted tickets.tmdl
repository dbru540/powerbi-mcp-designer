table 'Budgeted tickets'
	lineageTag: 3d83fa6d-bf86-4eb2-9f2a-5f7feaf4d19e

	measure 'Fixed price - Budget amount' =
			CALCULATE(sum('Budgeted tickets'[Amount]),
			                FILTER(
			                    'Budgeted tickets',
			                    CONTAINSSTRING('Budgeted tickets'[Type], "Fix") || CONTAINSSTRING('Budgeted tickets'[Type], "Fixed")
			                ),
			USERELATIONSHIP(Projects[Project Name],'Budgeted tickets'[Team Project]),
			                USERELATIONSHIP('Budgeted tickets'[Work Item Id],'Power BI - All projects'[FixedProjectRoot] ))
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		displayFolder: 1 - Measures
		lineageTag: cf7babfa-413f-47d8-b0ce-e4cedc02585b

	measure 'Fixed price - Margin' =
			
			IF(
			    (ISBLANK([Fixed price - Budget amount]) && ISBLANK([Fixed price - Actual amount])) ||
			    ([Fixed price - Budget amount]=0 && [Fixed price - Actual amount]=0) ||
			    (ISBLANK([Fixed price - Budget amount]) && [Fixed price - Actual amount]=0) ||
			    ([Fixed price - Budget amount]=0 && ISBLANK([Fixed price - Actual amount])),
			    BLANK(),
			    IF(
			        OR([Fixed price - Budget amount]=0,ISBLANK([Fixed price - Budget amount])),-1,
			        IF(
			            OR([Fixed price - Actual amount]=0,ISBLANK([Fixed price - Actual amount])),1,
			            1-[Fixed price - Actual amount]/[Fixed price - Budget amount]
			        )
			    )
			)
		formatString: 0%;-0%;0%
		displayFolder: 1 - Measures
		lineageTag: 60d1f93e-dda1-4644-854d-3e224713b0c7

	measure 'Fixed price - Tech time (%)' =
			
			DIVIDE(
			        CALCULATE(
			            [Fixed price - Actual amount],
			            FILTER('Consultants',CONTAINSSTRING('Consultants'[Activity],"developper"))
			            ),
			        CALCULATE(
			            [Fixed price - Actual amount]
			           )
			)
		displayFolder: 1 - Measures
		lineageTag: 364ea4dc-cb18-46bd-8018-7cc3210f98bb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Fixed price - Actual amount' = ```
			
			CALCULATE([Billable amount],
			                ALL('Calendar'),
			                FILTER(
			                    'Budgeted tickets',
			                    CONTAINSSTRING('Budgeted tickets'[Type], "Fix") || CONTAINSSTRING('Budgeted tickets'[Type], "Fixed")
			                ),
			                USERELATIONSHIP(Projects[Project Name],'Budgeted tickets'[Team Project]),
			                USERELATIONSHIP('Budgeted tickets'[Work Item Id],'Power BI - All projects'[FixedProjectRoot] )
			                 
			                 )
			```
		displayFolder: 1 - Measures
		lineageTag: 6694fb4c-2941-4b50-878c-414cc72a4310

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Fixed price - MarginColorCode of ongoing projects' = ```
			
			VAR CurrentMargin = [Fixed price - Margin]
			
			-- Check for Design activity conditions using the virtual table
			VAR IsDesignActivityMatch =
			CALCULATE(COUNTROWS('Power BI - All projects'),
			
			            'Power BI - All projects'[Activity] = "Design" &&
			            'Power BI - All projects'[State] IN {"New", "Active", "Resolved"}, 
			            USERELATIONSHIP(Projects[Project Name],'Budgeted tickets'[Team Project]),
			            USERELATIONSHIP('Budgeted tickets'[Work Item Id],'Power BI - All projects'[FixedProjectRoot] )
			         
			        ) > 0
			
			VAR IsEstimateActivityMatch =
			CALCULATE(COUNTROWS('Power BI - All projects'),
			
			            'Power BI - All projects'[Activity] = "Estimate" &&
			            'Power BI - All projects'[State] IN {"New", "Active", "Resolved"}, 
			            USERELATIONSHIP(Projects[Project Name],'Budgeted tickets'[Team Project]),
			            USERELATIONSHIP('Budgeted tickets'[Work Item Id],'Power BI - All projects'[FixedProjectRoot] )
			         
			        ) > 0
			        
			-- Check for Development activity conditions using the virtual table
			VAR IsDevelopmentActivityActive =
			CALCULATE(COUNTROWS('Power BI - All projects'),
			
			            'Power BI - All projects'[Activity] = "Development" &&
			            'Power BI - All projects'[State] IN {"New", "Active", "Resolved"}, 
			            USERELATIONSHIP(Projects[Project Name],'Budgeted tickets'[Team Project]),
			            USERELATIONSHIP('Budgeted tickets'[Work Item Id],'Power BI - All projects'[FixedProjectRoot] )
			         
			        ) > 0
			
			-- Check for Testing activity conditions using the virtual table
			VAR IsTestingActivityActive =
			CALCULATE(COUNTROWS('Power BI - All projects'),
			
			            'Power BI - All projects'[Activity] = "Testing" &&
			            'Power BI - All projects'[State] IN {"New", "Active", "Resolved"}, 
			            USERELATIONSHIP(Projects[Project Name],'Budgeted tickets'[Team Project]),
			            USERELATIONSHIP('Budgeted tickets'[Work Item Id],'Power BI - All projects'[Time & Materials Project Root] )
			         
			        ) > 0
			
			RETURN
			    IF(
			        NOT ISBLANK(CurrentMargin), 
			        -- Condition 1: Design activity, margin < 80%
			        IF(
			            (IsDesignActivityMatch || IsEstimateActivityMatch) && CurrentMargin < 0.8,
			            "#FF9999", -- Red
			            -- Condition 2: Development activity, margin < 40% (red)
			            IF(
			                IsDevelopmentActivityActive && CurrentMargin < 0.4,
			                "#FF9999", -- Red
			                -- Condition 3: Development activity, margin < 40% (orange)
			                IF(
			                    IsDevelopmentActivityActive && CurrentMargin < 0.5,
			                    "#FFCC99", -- Orange
			                    -- Condition 4: Testing activity, margin < 20% (red)
			                    IF(
			                        CurrentMargin < 0.2,
			                        "#FF9999", -- Red
			                        -- Condition 5: Testing activity, margin < 30% (orange)
			                        IF(
			                            IsTestingActivityActive && CurrentMargin < 0.3,
			                            "#FFCC99", -- Orange
			                            
			                            
			                            
			                            
			                            BLANK() -- No special formatting
			                        )
			                    )
			                )
			            )
			        ),
			        BLANK()
			    )
			```
		displayFolder: 1 - Measures
		lineageTag: a464ba31-b7b5-4b74-affe-8ab937fec03f

