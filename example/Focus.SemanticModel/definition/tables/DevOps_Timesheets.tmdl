table DevOps_Timesheets
	lineageTag: a1c5434f-1596-405a-8fae-84366adc09e1

	measure RecordedHours = CALCULATE(SUM(DevOps_Timesheets[PeriodLength])/3600)
		formatString: 0.0
		lineageTag: 32f1c501-a269-477b-8e07-0e7f18890c76

		changedProperty = FormatString

	measure Time = ```
			
			
			var _timetype = SELECTEDVALUE(TimeType[Time])
			RETURN
			
			IF(_timetype = "Per hour",
			    [BillableHours],
			    IF( _timetype = "Per day",IF([BillableHours]=0,0,
			    CALCULATE([BillableHours]/8)), 
			
			[Billable amount]))
			
			```
		formatString: #,0
		lineageTag: 6c9b0ff1-9eac-423d-a432-ee5d2f1fb821

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Billable amount' =
			
			CALCULATE(SUMX(DevOps_Timesheets,DevOps_Timesheets[Hourly price]*DevOps_Timesheets[BillablePeriodLength]/3600))
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		displayFolder: 1 - Measures
		lineageTag: 8c667fa5-b47e-4b4e-bba5-434cd3e881ed

	measure 'Internal Off Time with zero' =
			
			
			VAR StartOfCurrentMonth = DATE(YEAR(TODAY()),MONTH(TODAY()),1)
			
			VAR HoursCalc =
			    CALCULATE (
			        [RecordedHours],FILTER('Calendar','Calendar'[Date]>=StartOfCurrentMonth),
			        FILTER('Power BI - All projects','Power BI - All projects'[Parent Work Item Id] = 1602 && 'Power BI - All projects'[Work Item Id] <> 440)
			)
			
			RETURN
			    COALESCE( HoursCalc,0)
		lineageTag: 38279773-0d41-4281-b514-c85fe91d3488

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Internal Off Time Icon' =
			
			
			
			IF([Day measure] = 0, BLANK(),IF([Internal Off Time with zero]=0,BLANK(),IF([Internal Off Time with zero]=4,"CircleHalf",IF([Internal Off Time with zero]<4,"Circle25",IF([Internal Off Time with zero]>6 ,"CircleFilled","Circle75")))))
		lineageTag: fccc9014-a7e6-4cff-9277-b7cba55a9645

	measure 'Internal Off Time Color' = ```
			
			
			VAR _date = FIRSTDATE('Calendar'[Date])
			
			RETURN
			
			IF(   DATEDIFF(_date,today(),DAY)=0,"#22a7f0",IF(   [IsABankHoliday]=0,"#beb9db",IF([ToBeWorkedDay]=0,"#E1E1E1","2B2B2B"))
			)
			
			
			```
		lineageTag: 5a1803c8-404a-413f-a475-0680802e1dec

	measure ToBeWorkedDay = CALCULATE(SUM('Calendar'[ToBeWorkedDay]))
		formatString: 0
		lineageTag: 0af87d00-3c29-4734-ae25-4499e916c5f1

	measure IsABankHoliday = CALCULATE(SUM('Calendar'[NotABankHoliday]))
		formatString: 0
		lineageTag: ab649931-26da-4bd5-ae10-d72305b00318

	measure 'Internal Off Time - days' =
			calculate([RecordedHours]/8,'Power BI - All projects'[Parent Work Item Id]=1602 && 'Power BI - All projects'[Work Item Id]<>440
			)
		lineageTag: 8ae890b1-73b8-457b-9e69-5259863b9ab4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure BillableHours =
			
			CALCULATE(SUM(DevOps_Timesheets[BillablePeriodLength])/3600)
		displayFolder: 1 - Measures
		lineageTag: 96554c84-84f3-4ab4-9096-17660e73e747

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Time Final' = ```
			
			
			var _timetype = SELECTEDVALUE(TimeType[Time])
			RETURN
			
			IF(_timetype = "Per hour",
			    [BillableHours],
			    IF( _timetype = "Per day",[BillableHours]/8, 
			
			[Billable amount]))
			```
		formatString: #,0.00
		lineageTag: 65322aec-a14e-4dbd-9a65-6e5ad9b53190

	measure 'Time entries on already billed work items' = ```
			
			CALCULATE (
			    COUNTROWS('DevOps_Timesheets'),
			    FILTER (
			        'DevOps_Timesheets',
			        VAR ResolvedDate = RELATED('Power BI - All Projects'[Resolved Date])
			        VAR ClosedDate = RELATED('Power BI - All Projects'[Closed Date])
			        VAR EffectiveClose =
			            IF (
			                ISBLANK(ClosedDate),
			                ResolvedDate,
			                IF (
			                    ISBLANK(ResolvedDate),
			                    ClosedDate,
			                    MAX(ClosedDate, ResolvedDate)
			                )
			            )
			        RETURN
			            NOT ISBLANK(EffectiveClose) &&
			            EOMONTH('DevOps_Timesheets'[RecordDate], 0) > EOMONTH(EffectiveClose, 0)
			    )
			)
			
			
			```
		formatString: 0
		displayFolder: 1 - Measures
		lineageTag: 4d50168a-053e-4f9a-9ed6-5a9da0c141bb

	measure 'Billable (All Projects)' = ```
			
			CALCULATE(
			    [Billable Amount],
			    ALLSELECTED(Projects[Project Name])
			)
			
			```
		displayFolder: 1 - Measures
		lineageTag: 7b37b113-6828-4f09-9c9b-a2d03794c278

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Billable (Linked Only)' =
			
			CALCULATE(
			  [Billable Amount],ALL(Projects),ALL('Power BI - All projects'),                            // your base SUMX measure
			  FILTER(
			    DevOps_Timesheets,                             // iterate every timesheet row
			    NOT ISBLANK(                                   // keep only those...
			      RELATED( 'Power BI - All projects'[Work Item Id] )
			    )
			  )
			)
		displayFolder: 1 - Measures
		lineageTag: f1b0290a-65da-4a3a-9470-a83a4d3a9d47

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Compare = [Billable (All Projects)] - [Billable (Linked Only)]
		displayFolder: 1 - Measures
		lineageTag: 3b94a091-01d8-416a-8014-b85b830a062f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Recorded amount' =
			
			CALCULATE(SUMX(DevOps_Timesheets,DevOps_Timesheets[Hourly price]*DevOps_Timesheets[RecordedHours]))
		lineageTag: 28d1c703-8da7-404a-9c30-49d640c68a70

